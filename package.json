{
  "name": "kommo-mcp-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r build",
    "clean": "pnpm -r clean",
    "format": "prettier --write \"**/*.{js,ts,json,yml,yaml}\" \"CONTRIBUTING.md\"",
    "lint": "eslint . && prettier --check \"**/*.{js,ts,json,yml,yaml}\" \"CONTRIBUTING.md\"",
    "test": "vitest run",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  }
}
