# Configuração do Kommo MCP Server (M1 — modo stdio/headless).
#
# Copie para `.env` e preencha com seus valores. NUNCA commite `.env` — ele já
# está no .gitignore. Estes nomes são canônicos (spec 002) e reutilizados pela
# spec 007 / integração de clientes MCP.

# Subdomínio da conta Kommo (ex.: "minhaempresa" em https://minhaempresa.kommo.com).
KOMMO_SUBDOMAIN=

# Token de longa duração (Integrações → API → Chave de API).
# Enviado como "Authorization: Bearer {token}".
KOMMO_ACCESS_TOKEN=
